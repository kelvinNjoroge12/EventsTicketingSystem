# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://eventhub:eventhub@db:5432/eventhub
CONN_MAX_AGE=0

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SERVICE_FEE_PERCENT=3.0

# Location autocomplete
MAPBOX_ACCESS_TOKEN=

# M-Pesa Daraja
MPESA_CONSUMER_KEY=...
MPESA_CONSUMER_SECRET=...
MPESA_SHORTCODE=174379
MPESA_PASSKEY=...
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback/
MPESA_ENVIRONMENT=sandbox

# SendGrid
SENDGRID_API_KEY=SG....
DEFAULT_FROM_EMAIL=noreply@eventhub.co.ke
ASYNC_TICKET_EMAIL=True

# AWS S3 / Cloudflare R2
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_STORAGE_BUCKET_NAME=eventhub-media
AWS_S3_ENDPOINT_URL=https://...r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://eventhub.co.ke

# Rate limiting toggle
RATELIMIT_ENABLE=True

# Checkout simulation mode (set True in dev only)
ENABLE_SIMULATED_PAYMENTS=True
SIMULATED_PAYMENT_TOKEN_MAX_AGE_SECONDS=3600
